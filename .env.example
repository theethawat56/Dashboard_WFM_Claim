# Turso (libSQL) — required for the app to connect
# How to get these: see docs/TURSO_SETUP.md
TURSO_DATABASE_URL=libsql://your-db-name-your-org.region.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# For npm run db:setup: use the EXACT name from "turso db list"
# Example: turso db list → copy one name → TURSO_DB_NAME=that-name
# TURSO_DB_NAME=your-actual-db-name

# Optional: Full path to Turso CLI binary if not in PATH (e.g. after install: ~/.turso/turso)
# TURSO_CLI_PATH=/Users/yourname/.turso/turso

# Optional: set to true to skip migrate (use after creating tables manually; see README)
# SKIP_MIGRATE=true

# Search API (reference only — endpoint is hardcoded)
# POST https://open-api.dataslot.app/search/wfm/v1/RobotMaker
